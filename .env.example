# ===============================
# アプリケーション設定
# ===============================

# 実行環境（development: 開発 / production: 本番）
NODE_ENV=development

# サーバーの起動ポート
PORT=5000


# ===============================
# データベース設定（NestJS / TypeORM）
# ===============================

# DBのホスト（通常はlocalhost or Dockerコンテナ名）
DB_HOST=localhost

# DBのポート（MySQLは通常3306）
DB_PORT=3306

# DB接続ユーザー名
DB_USER=user

# DB接続パスワード（Gitに絶対に含めない）
DB_PASSWORD=password_please

# 使用するデータベース名
DB_NAME=my_app_db

# エンティティから自動でテーブルを生成するか
# true: 開発用（簡単だが危険）
# false: 本番・チーム開発用（マイグレーション推奨）
DB_SYNCHRONIZE=false


# ===============================
# Docker用 MySQL設定
# ===============================

# MySQLのrootユーザーのパスワード（DB初期化時に使用）
MYSQL_ROOT_PASSWORD=root